# Port the backend listens on (defaults to 8787 if unset).
PORT=8787

# Which model gateway llm/client.ts routes through. "insforge" (default) or "openrouter".
# Set to "openrouter" until the InsForge gateway is wired at S2.
LLM_PROVIDER=insforge

# InsForge gateway key (model gateway + db + auth). Filled at S2.
INSFORGE_API_KEY=

# OpenRouter fallback gateway key (the build runs on this until InsForge is wired).
OPENROUTER_API_KEY=

# You.com Research/Search — citation-backed external grounding.
YOU_API_KEY=

# --- Optional sponsor integrations (off by default; set ENABLED=true to use) ---
# Nebius Token Factory — OpenAI-compatible inference + embeddings.
# Route all models here with LLM_PROVIDER=nebius; nebiusEmbed() powers people-similarity.
NEBIUS_ENABLED=false
NEBIUS_API_KEY=
# Tavily — a second public-footprint search lens alongside You.com.
TAVILY_ENABLED=false
TAVILY_API_KEY=
